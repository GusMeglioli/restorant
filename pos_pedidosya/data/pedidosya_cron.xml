<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_pedidosya_reconcile" model="ir.cron">
            <field name="name">PedidosYa: Daily Order Reconciliation</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">env['pedidosya.sync'].reconcile_orders()</field>
