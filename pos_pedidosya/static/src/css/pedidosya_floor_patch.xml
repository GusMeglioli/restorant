<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
        Heredamos el template del FloorScreen de Odoo 19 para agregar
        el botón PedidosYa en la esquina superior derecha de la pantalla de mesas.
    -->
    <t t-name="pos_pedidosya.FloorScreenPatch" t-inherit="point_of_sale.FloorScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('floor-screen')]" position="inside">
            <PedidosYaButton/>
        </xpath>
    </t>

</templates>
