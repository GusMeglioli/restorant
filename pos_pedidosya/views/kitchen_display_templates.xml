<body>
<header>
  <div style="display:flex;align-items:center;gap:10px;">
    <h1>🛵 Listo para retirar</h1>
    <span id="badge">0</span>
  </div>
  <div style="display:flex;align-items:center;gap:12px;">
    <button id="sound-btn" onclick="toggleSound()">🔔 ON</button>
    <span class="clock" id="clock">--:--</span>
  </div>
</header>

<div id="grid"></div>
<div id="empty">
  <span style="font-size:3rem;">🏍️</span>
  <span>Sin pedidos listos para retirar</span>
</div>

<script>
const POLL_MS = 6000;
let soundOn = true;
let knownIds = new Set();

function toggleSound() {
  soundOn = !soundOn;
  document.getElementById('sound-btn').textContent = soundOn ? '🔔 ON' : '🔕 OFF';
}

function playAlert() {
  if (!soundOn) return;
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    [523, 659, 784].forEach((freq, i) => {
      setTimeout(() => {
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);
        o.frequency.value = freq;
        g.gain.setValueAtTime(0.4, ctx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.4);
        o.start(ctx.currentTime);
        o.stop(ctx.currentTime + 0.4);
      }, i * 300);
    });
  } catch(e) {}
}

async function markDispatched(orderId, btn) {
  btn.disabled = true;
  btn.textContent = '⏳...';
  try {
    const r = await fetch('/pedidosya/ready/dispatched/' + orderId, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({jsonrpc:'2.0',method:'call',params:{}})
    });
    const d = await r.json();
    if (d.result && d.result.status === 'ok') {
      const card = document.getElementById('card-' + orderId);
      if (card) {
        card.style.transition = 'opacity 0.4s';
        card.style.opacity = '0';
        setTimeout(() => card.remove(), 400);
      }
    } else {
      btn.disabled = false;
      btn.textContent = '🏍️ Entregado al rider';
    }
  } catch(e) {
    btn.disabled = false;
    btn.textContent = '🏍️ Entregado al rider';
  }
}

async function fetchOrders() {
  try {
    const r = await fetch('/pedidosya/ready/orders', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({jsonrpc:'2.0',method:'call',params:{}})
    });
    const d = await r.json();
    const orders = d.result || [];
    const grid = document.getElementById('grid');
    const empty = document.getElementById('empty');
    const badge = document.getElementById('badge');

    const newIds = new Set(orders.map(o => o.id));
    let hasNew = false;
    newIds.forEach(id => { if (!knownIds.has(id)) hasNew = true; });
    if (hasNew && knownIds.size > 0) playAlert();
    knownIds = newIds;

    badge.textContent = orders.length;
    document.title = orders.length > 0 ? `(${orders.length}) 🛵 Listo` : '🛵 Listo para retirar';

    if (orders.length === 0) {
      grid.innerHTML = '';
      empty.style.display = 'flex';
      return;
    }
    empty.style.display = 'none';

    const existing = new Set([...grid.querySelectorAll('.card')].map(c => c.id));
    orders.forEach(o => {
      const cardId = 'card-' + o.id;
      if (document.getElementById(cardId)) return;
      const card = document.createElement('div');
      card.className = 'card';
      card.id = cardId;
      const linesHtml = (o.lines || []).map(l =>
        `<li><span class="qty">${l.quantity}x</span><span>${l.product_name}</span></li>`
      ).join('');
      card.innerHTML = `
        <span class="ready-badge">✅ LISTO</span>
        <div class="order-num"># ${o.platform_order_id || o.id}</div>
        <div class="customer">👤 ${o.customer_name || 'Cliente'}</div>
        <ul class="lines">${linesHtml}</ul>
        <button class="btn-dispatched" onclick="markDispatched(${o.id}, this)">🏍️ Entregado al rider</button>
      `;
      grid.appendChild(card);
    });

    existing.forEach(id => {
      if (!newIds.has(parseInt(id.replace('card-', '')))) {
        const el = document.getElementById(id);
        if (el) el.remove();
      }
    });
  } catch(e) {
    console.error('Ready fetch error:', e);
  }
}

function updateClock() {
  document.getElementById('clock').textContent =
    new Date().toLocaleTimeString('es-AR', {hour:'2-digit', minute:'2-digit', second:'2-digit'});
}

fetchOrders();
setInterval(fetchOrders, POLL_MS);
setInterval(updateClock, 1000);
updateClock();
</script>
</body>
