<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Logo de empresa (facturas, reportes, header) ────────────────── -->
    <record id="main_company_branding" model="res.company">
        <field name="id" ref="base.main_company"/>
        <field name="logo" type="base64" file="gm_branding/static/src/img/gm_logo.png"/>
    </record>

    <!-- ── Favicon personalizado ────────────────────────────────────────── -->
    <record id="favicon_branding" model="res.company">
        <field name="id" ref="base.main_company"/>
        <field name="favicon" type="base64" file="gm_branding/static/src/img/favicon.png"/>
    </record>

    <!-- ── Color primario de UI (tema Odoo Enterprise) ──────────────────── -->
    <record id="primary_color_param" model="ir.config_parameter">
        <field name="key">web.primary_color</field>
        <field name="value">#ff5d00</field>
    </record>

    <record id="secondary_color_param" model="ir.config_parameter">
        <field name="key">web.secondary_color</field>
        <field name="value">#202020</field>
    </record>
</odoo>
